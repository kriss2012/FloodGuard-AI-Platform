
# FloodGuard AI — Environment Variables
# Copy this to .env and set values

# ------------------------------------------------------------------
# OPTIONAL: Groq API Key for real LLM-powered AI reasoning
# Get free key at: https://console.groq.com
# Without this, the app uses a deterministic fallback AI engine
# ------------------------------------------------------------------
VITE_GROQ_API_KEY=your_groq_api_key_here

# ------------------------------------------------------------------
# Open-Meteo APIs — COMPLETELY FREE, NO KEY NEEDED
# Weather: https://api.open-meteo.com/v1/forecast
# Flood:   https://flood-api.open-meteo.com/v1/flood
# ------------------------------------------------------------------

# ------------------------------------------------------------------
# OPTIONAL: OpenWeatherMap (for additional weather layers)
# Get free key at: https://openweathermap.org/api
# ------------------------------------------------------------------
VITE_OPENWEATHER_API_KEY=your_openweathermap_key_here
